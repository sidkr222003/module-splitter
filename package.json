{
  "name": "astra-module-splitter",
  "displayName": "ASTra — Module Splitter",
  "description": "Automated, metrics-driven TypeScript/React module decomposition. Splits large files into well-structured modules with correct imports, test scaffolds, and dependency analysis.",
  "version": "3.0.0",
  "publisher": "NK2552003",
  "author": {
    "name": "Nitish Kumar",
    "email": "dev@nitish.world"
  },
  "license": "MIT",
  "homepage": "https://github.com/NK2552003/astra-extension",
  "repository": {
    "type": "git",
    "url": "https://github.com/NK2552003/astra-extension"
  },
  "bugs": {
    "url": "https://github.com/NK2552003/astra-extension/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "typescript",
    "refactoring",
    "module",
    "splitter",
    "react",
    "metrics",
    "code quality",
    "ast"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onCommand:astra.analyseFile",
    "onCommand:astra.applySplit",
    "onCommand:astra.showMetrics",
    "onCommand:astra.clearDiagnostics"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "astra.analyseFile",
        "title": "ASTra: Analyse & Split This Module",
        "icon": "$(split-horizontal)",
        "category": "ASTra"
      },
      {
        "command": "astra.applySplit",
        "title": "ASTra: Apply Split Plan",
        "icon": "$(check)",
        "category": "ASTra"
      },
      {
        "command": "astra.showMetrics",
        "title": "ASTra: Show File Metrics",
        "icon": "$(graph)",
        "category": "ASTra"
      },
      {
        "command": "astra.clearDiagnostics",
        "title": "ASTra: Clear Diagnostics",
        "icon": "$(clear-all)",
        "category": "ASTra"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "astra.analyseFile",
          "when": "resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "astra.analyseFile",
          "when": "resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/",
          "group": "astra@1"
        },
        {
          "command": "astra.showMetrics",
          "when": "resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/",
          "group": "astra@2"
        },
        {
          "command": "astra.applySplit",
          "when": "resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/",
          "group": "astra@3"
        }
      ],
      "explorer/context": [
        {
          "command": "astra.analyseFile",
          "when": "resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/",
          "group": "astra@1"
        },
        {
          "command": "astra.showMetrics",
          "when": "resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/",
          "group": "astra@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "astra.analyseFile",
        "key": "ctrl+shift+alt+s",
        "mac": "cmd+shift+alt+s",
        "when": "editorTextFocus && resourceExtname =~ /\\.(ts|tsx|js|jsx|vue|svelte)$/"
      },
      {
        "command": "astra.applySplit",
        "key": "ctrl+shift+alt+a",
        "mac": "cmd+shift+alt+a",
        "when": "astraHasPlan"
      }
    ],
    "configuration": {
      "title": "ASTra Module Splitter",
      "properties": {
        "astra.extractionThreshold": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 0.9,
          "default": 0.35,
          "markdownDescription": "ExtractionOracle score threshold. Higher = fewer extractions (default: `0.35`). Range: `0.1`–`0.9`."
        },
        "astra.testFramework": {
          "type": "string",
          "enum": [
            "auto",
            "jest",
            "vitest"
          ],
          "enumDescriptions": [
            "Auto-detect from package.json",
            "Always use Jest",
            "Always use Vitest"
          ],
          "default": "auto",
          "description": "Test framework for generated test scaffolds."
        },
        "astra.showOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run analysis automatically on every file save."
        },
        "astra.showInlineSmells": {
          "type": "boolean",
          "default": true,
          "description": "Show code smell diagnostics as inline squiggles in the editor."
        },
        "astra.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show health grade in the status bar for the active file."
        },
        "astra.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Apply split plan automatically without review. Use with caution."
        },
        "astra.typesFile": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to existing types file for routing type blocks (e.g. `src/types.ts`). Leave empty to auto-detect."
        },
        "astra.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.d.ts",
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**"
          ],
          "description": "Glob patterns to exclude from analysis."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "package": "vsce package",
    "publish": "vsce publish",
    "clean": "rimraf out"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "__tests__/tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/extension.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 57,
        "functions": 65,
        "lines": 71,
        "statements": 69
      }
    }
  }
}
